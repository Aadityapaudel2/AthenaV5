# Copy this file to "portal_auth.env" in the project root and fill values.
# run_portal_v5.ps1 auto-loads portal_auth.env if present.

ATHENA_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ATHENA_GOOGLE_CLIENT_SECRET=your-google-client-secret
ATHENA_PORTAL_SESSION_SECRET=replace-with-long-random-string
ATHENA_AUTH_REDIRECT_URI=https://portal.neohmlabs.com/AthenaV5/auth/callback
